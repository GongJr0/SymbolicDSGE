# Bundled web UI assets (generated by scripts/build_frontend.py; gitignored).
# Listed here so they are included in the sdist as well as the wheel.
recursive-include SymbolicDSGE/ui/_static *

# Native-kernel sources so wheels can be built from the sdist.
recursive-include SymbolicDSGE/ckernels *.pyx *.pxd *.c *.h
